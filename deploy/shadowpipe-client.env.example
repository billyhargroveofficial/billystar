# One whitespace-split systemd EnvironmentFile value. Keep paths free of spaces.
# The signed bundle must contain literal IPv4 carrier seeds. Replace every
# placeholder before enabling shadowpipe-client-full-tunnel.service.
SHADOWPIPE_CLIENT_ARGS=--client-credential /etc/shadowpipe/client-credential.json --tunnel --auto-route --kill-switch --dns 10.8.0.1 --policy-bundle /etc/shadowpipe/policy.cbor --policy-root-kid REPLACE_32_HEX --policy-root-key REPLACE_64_HEX --host-state-dir /var/lib/shadowpipe
